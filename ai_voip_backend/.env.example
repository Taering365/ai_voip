# PostgreSQL 配置
AIVOIP_PG_HOST=127.0.0.1
AIVOIP_PG_PORT=5432
AIVOIP_PG_USER=postgres
AIVOIP_PG_PASSWORD=<CHANGE_ME>
AIVOIP_PG_DATABASE=ai_voip
AIVOIP_PG_SSLMODE=prefer

# JWT 配置
AIVOIP_JWT_SECRET=<CHANGE_ME_TO_AT_LEAST_32_CHARS>
AIVOIP_JWT_EXPIRE_MINUTES=1440
AIVOIP_TOKEN_ENCRYPTION_KEY=<CHANGE_ME_TO_AT_LEAST_32_CHARS>

